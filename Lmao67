 local function validateDuration(text)
 local num = tonumber(text)
 if num and num >= 0.1 and num <= 2.0 then
 return num, true
 else
 return FreezeDuration, false
 end
 end

 local function validateWidth(text)
 local num = tonumber(text)
 if num and num >= 100 and num <= 700 then
 return math.floor(num), true
 else
 return UIWidth, false
 end
 end

 local function validateHeight(text)
 local num = tonumber(text)
 if num and num >= 50 and num <= 350 then
 return math.floor(num), true
 else
 return UIHeight, false
